{
  "mcpServers": {
    "wave-os": {
      "command": "node",
      "args": ["./wave-mcp-server/dist/index.js"],
      "env": {
        "BASE44_APP_ID": "YOUR_APP_ID_HERE",
        "BASE44_API_KEY": "YOUR_API_KEY_HERE",
        "MCP_ENCRYPTION_KEY": "SET_A_RANDOM_STRING_HERE_FOR_AES256",
        "THETA_API_KEY": "OPTIONAL_YOUR_THETA_API_KEY",
        "THETA_PROJECT_ID": "OPTIONAL_YOUR_THETA_PROJECT_ID",
        "THETA_ALLOW_WRITES": "false"
      }
    }
  }
}
